{
  "_comment": "Example only. Never commit real credentials. Prefer environment variables or a private setting.json.",
  "llm_services": [
    {
      "name": "example-openai-compatible",
      "enable": false,
      "base_url": "https://api.example.com/v1",
      "api_key": "YOUR_LLM_API_KEY",
      "type": "openai-compatible",
      "model": "example-model",
      "context_window_tokens": 131072,
      "reserve_output_tokens": 16384,
      "compact_trigger_ratio": 0.85
    }
  ],
  "default_llm_server": null,
  "ghost": {
    "enabled": false,
    "api_url": "https://your-ghost.example",
    "admin_api_key": "YOUR_INTEGRATION_ID:YOUR_ADMIN_SECRET",
    "content_api_key": "YOUR_CONTENT_API_KEY",
    "auto_publish": false
  },
  "search_keys": {
    "tavily_api_key": "YOUR_TAVILY_API_KEY",
    "brave_api_key": "YOUR_BRAVE_API_KEY"
  }
}
